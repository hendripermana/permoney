# =============================================================================
# Permoney Environment Variables — Template
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# Loading: Prisma does NOT auto-load .env. The project uses `prisma.config.ts`
# which calls `import "dotenv/config"` to bridge env vars into the Prisma CLI.
# Application runtime (Vite+) auto-loads .env via Vite's standard mechanism.

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
# LibSQL / SQLite connection string consumed by both:
#   1. Prisma CLI (migrations, generate)
#   2. Runtime (`@prisma/adapter-libsql` in src/server/db.server.ts)
#
# Local development (embedded SQLite file):
DATABASE_URL="file:./prisma/dev.db"
#
# Production (Turso edge replica):
# DATABASE_URL="libsql://<your-db>-<your-org>.turso.io"
# DATABASE_AUTH_TOKEN="<turso-jwt-token>"

# -----------------------------------------------------------------------------
# Auth (FUTURE — not yet wired, see ADRs)
# -----------------------------------------------------------------------------
# AUTH_SECRET="<openssl rand -base64 32>"
# AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# Observability (FUTURE)
# -----------------------------------------------------------------------------
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="development"
