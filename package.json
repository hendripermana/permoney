{
  "name": "permoney",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --port 3006",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "test:unit": "vp test run",
    "test:unit:coverage": "vp test run --coverage",
    "test:integration": "vp test run --config vitest.integration.config.ts",
    "test:e2e": "vp exec playwright test",
    "test:ci": "vp run test:unit:coverage && vp run test:integration",
    "test:watch": "vp test watch",
    "test:related": "vp test related",
    "lint": "vp lint",
    "lint:no-use-effect": "node scripts/check-no-use-effect.mjs",
    "format": "vp fmt",
    "check": "vp check && node scripts/check-no-use-effect.mjs && node scripts/check-pre-auth-stub.mjs",
    "typecheck": "vp check --type-aware",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:nuke": "docker compose down -v",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "prepare": "vp config",
    "postinstall": "prisma generate"
  },
