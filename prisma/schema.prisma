generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Postgres in dev (via docker-compose, see ADR-0003) and prod (managed
  // Postgres: Neon / Supabase / RDS). The runtime adapter is
  // `@prisma/adapter-pg` selected in `src/server/db.server.ts`. The
  // `url` is intentionally NOT declared here — Prisma 7 reads it from
  // `prisma.config.ts` (`datasource.url`) for migrations and from
  // `process.env.DATABASE_URL` at runtime via the adapter.
  provider = "postgresql"
}

model Iso4217Currency {
  code     String  @id
  isActive Boolean @default(true) @map("is_active")

  accounts                         Account[]     @relation("AccountCurrency")
  families                         Family[]      @relation("FamilyCurrency")
  transactionCurrencies            Transaction[] @relation("TransactionCurrency")
  transactionDestinationCurrencies Transaction[] @relation("TransactionDestinationCurrency")
  transactionBaseCurrencies        Transaction[] @relation("TransactionBaseCurrency")
  valuationCurrencies              Valuation[]   @relation("ValuationCurrency")
  valuationBaseCurrencies          Valuation[]   @relation("ValuationBaseCurrency")
  fxFromCurrencies                 FxRateSnapshot[] @relation("FxRateFromCurrency")
  fxToCurrencies                   FxRateSnapshot[] @relation("FxRateToCurrency")
  budgetCurrencies                 Budget[]      @relation("BudgetCurrency")

  @@map("iso_4217_currency")
}

model Family {
  id   String @id @default(cuid())
  name String

  // Fitur Enterprise: Setting default keluarga
  currency         String          @default("IDR")
  timezone         String          @default("Asia/Jakarta")
  currencyRegistry Iso4217Currency @relation("FamilyCurrency", fields: [currency], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "family_currency_is_iso_4217")

  users        User[]
  members      FamilyMember[]
  accounts     Account[]
  merchants    Merchant[]
  categories   Category[]
  smartRules   SmartRule[]
  transactions Transaction[]
  idempotencyRecords IdempotencyRecord[]
  valuations   Valuation[]
  fxRateSnapshots FxRateSnapshot[]
  budgets      Budget[]
  importBatches ImportBatch[]
  rawImportedTransactions RawImportedTransaction[]
  importBatchArtifacts ImportBatchArtifact[]
}

// ADR-0036: first-class family membership + role authorization.
//
// Authoritative record of WHO belongs to a family and with WHAT role.
// `User.familyId` is demoted to a denormalized "active family" pointer;
// this table is the source of truth for membership and capability.
//
// `role`/`status` are String + DB CHECK domains (house convention, not Prisma
// enums — mirrors Account.status / Transaction.kind). One row per
// (familyId, userId); removal soft-revokes and re-add reactivates the same row,
// so the simple @@unique holds without a partial index.
//
// Tenant access is driven by an `active` row here at BOTH layers:
//   - app: familyMiddleware resolves role -> requireCapability(cap)
//   - db:  app_is_active_member() guard on every tenant-table RLS policy
// See migration 20260620_000000_family_membership for the SQL contract.
model FamilyMember {
  id          String    @id @default(cuid())
  familyId    String
  userId      String
  role        String    @default("member") // 'owner' | 'admin' | 'member' | 'viewer' (DB CHECK)
  status      String    @default("active") // 'active' | 'invited' | 'revoked' (DB CHECK)
  invitedById String?
  invitedAt   DateTime?
  joinedAt    DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  family    Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user      User   @relation("FamilyMembership", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?  @relation("FamilyMemberInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([familyId, userId])
  @@index([familyId, status])
  @@index([userId])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  emailVerifiedAt DateTime?
  passwordHash    String

  // Fitur Enterprise: Preferensi tampilan user
  theme String @default("system")

  familyId      String?
  family        Family?       @relation(fields: [familyId], references: [id])
  memberships   FamilyMember[] @relation("FamilyMembership")
  invitedMembers FamilyMember[] @relation("FamilyMemberInvitedBy")
  transactions  Transaction[]
  sessions      Session[]
  emailVerified Boolean       @default(false)
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  authaccounts  AuthAccount[]

  @@map("User")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  token     String
  ipAddress String?

  @@unique([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("Session")
}

model Account {
  id   String @id @default(cuid())
  name String

  // Taxonomy contract: class controls normal balance, type controls ledger
  // capabilities, subtype describes product family without rewriting ledger
  // semantics. See docs/account-taxonomy.md.
  accountClass   String
  accountType    String
  accountSubtype String
  // Cash-like vs tracked-asset distinction (M2.5-4 / PER-143). "transaction_flow"
  // means the balance is posted by canonical Transaction rows; "valuation" means
  // it is driven by point-in-time valuations (TRACKED_ASSET only). Derived from
  // accountType and enforced consistent by a DB CHECK so it can never drift.
  // See docs/account-taxonomy.md and ADR-0008 §6.
  balanceSource  String @default("transaction_flow")
  // Stored in MINOR UNITS (sen for IDR, cents for USD, satoshi for BTC).
  // Per-currency scale is driven by `CURRENCIES[code].minorUnitConversion`
  // in src/lib/data/currencies.ts. See docs/adr/0001-money-type-migration.md.
  balance          BigInt
  version          Int             @default(0) @map("version")
  currency         String          @default("IDR") // Bisa USD, JPY, dll
  currencyRegistry Iso4217Currency @relation("AccountCurrency", fields: [currency], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "account_currency_is_iso_4217")

  // Fitur Enterprise: Visual & Status
  color      String? // Hex color misal "#3b82f6"
  status     String    @default("active") // "active" atau "closed"
  archivedAt DateTime?

  // Soft Delete (PER-183): a deleted account is set to status="closed" +
  // archivedAt together with deletedAt, so every existing status/archivedAt
  // filter already excludes it defensively. deletedAt is the authoritative
  // "is this account gone" signal. NULL = active-or-archived, timestamp =
  // deleted (audit trail preserved; the row itself is only ever physically
  // removed when it never had any transaction/valuation history — see
  // deleteAccountForFamily in src/server/accounts.ts).
  deletedAt DateTime?

  // Optional provider/capability metadata. These fields describe integrations
  // and product behaviour; they do not change ledger semantics.
  institutionName   String?
  externalProvider  String?
  externalAccountId String?
  mask              String?
  isImportable      Boolean @default(false)
  creditLimit       BigInt?
  statementDay      Int?
  dueDay            Int?
  interestRateBps   Int?

  familyId String
  family   Family @relation(fields: [familyId], references: [id])

  transactionsFrom Transaction[] @relation("FromAccount")
  transactionsTo   Transaction[] @relation("ToAccount")
  valuations       Valuation[]
  rawImportedTransactions RawImportedTransaction[]

  // Tenant-scoped fetch (every Account read is filtered by familyId once
  // ADR-0004 lands; cheap to add now). See ADR-0003.
  @@unique([id, familyId], map: "Account_id_familyId_key")
  @@index([familyId])
  @@index([familyId, accountClass, accountType])
  @@index([familyId, status])
  @@index([familyId, deletedAt])
  @@index([familyId, externalProvider, externalAccountId])
}

model Merchant {
  id   String @id @default(cuid())
  name String

  // Fitur Enterprise: Logo/Website
  color   String?
  logoUrl String?

  // Durable external-provider binding (ADR-0041 §3, mirrors Account). NULL for
  // manually-created merchants. A PARTIAL UNIQUE (familyId, externalProvider,
  // externalId) WHERE externalProvider IS NOT NULL is created in raw SQL
  // (migration `sure_migration_bindings`) — Prisma cannot express the predicate.
  externalProvider String?
  externalId       String?

  familyId     String
  family       Family        @relation(fields: [familyId], references: [id])
  transactions Transaction[]
  splitEntries SplitEntry[]
  smartRules   SmartRule[]

  // Tenant scoping (see ADR-0003).
  // PER-189: case/whitespace-insensitive per-family name uniqueness for
  // MANUALLY-created merchants only — a functional UNIQUE INDEX (familyId,
  // lower(btrim(name))) WHERE externalProvider IS NULL is created in raw SQL
  // (migration `merchant_category_name_dedup`, narrowed by the follow-up
  // `merchant_category_name_dedup_exempt_migrated`). Migration-bound rows are
  // exempt: Sure identity is externalId-bound, not name-bound, so two
  // distinct Sure merchants may share a case-insensitive name. Prisma cannot
  // express a functional index in the schema DSL.
  @@unique([id, familyId], map: "Merchant_id_familyId_key")
  @@index([familyId])
}

model Category {
  id   String @id @default(cuid())
  name String
  type String // "expense" atau "income"

  // Fitur Enterprise: Visual Category
  color String @default("#6172F3")
  icon  String @default("shapes") // Referensi nama icon dari Tabler/Lucide

  isSystem Boolean @default(false)
  familyId String?
  family   Family? @relation(fields: [familyId], references: [id])

  // Durable external-provider binding (ADR-0041 §3, mirrors Account). NULL for
  // manually-created and system categories. A PARTIAL UNIQUE (familyId,
  // externalProvider, externalId) WHERE externalProvider IS NOT NULL is created
  // in raw SQL (migration `sure_migration_bindings`). Sure categories are always
  // TENANT-owned (familyId set, isSystem=false); system rows are out of scope.
  externalProvider String?
  externalId       String?

  parentId     String?
  parent       Category?     @relation("SubCategories", fields: [parentId], references: [id])
  children     Category[]    @relation("SubCategories")
  transactions Transaction[]
  splitEntries SplitEntry[]
  smartRules   SmartRule[]
  budgetCategories BudgetCategory[]

  // Tenant scoping (see ADR-0003). `familyId` is nullable for system
  // categories; the index still helps the common per-family scan.
  // PER-189: case/whitespace-insensitive per-family name uniqueness for
  // MANUALLY-created categories only — a functional UNIQUE INDEX (familyId,
  // lower(btrim(name))) WHERE familyId IS NOT NULL AND externalProvider IS
  // NULL is created in raw SQL (migration `merchant_category_name_dedup`,
  // narrowed by the follow-up `merchant_category_name_dedup_exempt_migrated`).
  // System categories (familyId NULL) and migration-bound rows (Sure identity
  // is externalId-bound, not name-bound) are both out of scope. Prisma cannot
  // express a functional index in the schema DSL.
  @@index([familyId])
}

model Transaction {
  id               String          @id @default(cuid())
  // Stored in MINOR UNITS of `currency`. Negative for outflow, positive for inflow.
  // See src/lib/money.ts for arithmetic helpers; never use raw `+ -` on this field.
  amount           BigInt
  type             String // "expense", "income", "transfer"
  kind             String          @default("standard")
  currency         String          @default("IDR")
  currencyRegistry Iso4217Currency @relation("TransactionCurrency", fields: [currency], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "currency_is_iso_4217")

  // Transaction Lifecycle Status: PENDING (gantung), CLEARED (selesai), RECONCILED (dicocokkan)
  status String @default("CLEARED")

  // Multi-Currency Transfer Support (Implied Rate Architecture)
  // User menginput nominal yang benar-benar masuk ke akun tujuan, bukan hanya tebakan kurs API.
  // Stored in MINOR UNITS of `destinationCurrency`.
  destinationAmount           BigInt?
  destinationCurrency         String?
  destinationCurrencyRegistry Iso4217Currency? @relation("TransactionDestinationCurrency", fields: [destinationCurrency], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "destination_currency_is_iso_4217")

  // Base-currency projection (ADR-0035 §4). Derived, rebuildable; materialized at
  // write time from a dated FxRateSnapshot. All-three-or-none: present when
  // converted, NULL when "FX-pending" (native != base and no rate resolved).
  // `fxRateScaled` is the 1e12-scaled rate used (IDENTITY_RATE when native==base).
  // `fxRateSnapshotId` is a provenance pointer (plain id, no FK — like createdById).
  baseAmount       BigInt?
  baseCurrency     String?
  baseCurrencyRegistry Iso4217Currency? @relation("TransactionBaseCurrency", fields: [baseCurrency], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "transaction_base_currency_is_iso_4217")
  fxRateScaled     BigInt?
  fxRateSnapshotId String?

  date DateTime @default(now())

  description String
  notes       String?
  excluded    Boolean @default(false)

  // Running Balance Snapshot: Saldo akun setelah transaksi ini dicatat (untuk grafik historis instan).
  // Stored in MINOR UNITS of `currency`.
  accountBalanceAfter BigInt?

  // Proof of Purchase: URL struk/foto kwitansi (S3/Cloudflare R2)
  attachmentUrl String?

  // Soft Delete (GAAP Compliance): Transaksi tidak pernah benar-benar dihapus
  // NULL = aktif, ada timestamp = soft-deleted (audit trail tetap ada)
  deletedAt               DateTime?
  supersededBy            String?       @unique
  supersededByTransaction Transaction?  @relation("TransactionSupersededBy", fields: [supersededBy], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supersedes              String?       @unique
  supersedesTransaction   Transaction?  @relation("TransactionSupersedes", fields: [supersedes], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supersededTransactions  Transaction[] @relation("TransactionSupersedes")
  supersedingTransactions Transaction[] @relation("TransactionSupersededBy")
  idempotencyKey          String?

  merchantId String?
  merchant   Merchant? @relation(fields: [merchantId, familyId], references: [id, familyId], onDelete: Restrict, onUpdate: Cascade, map: "Transaction_merchantId_familyId_fkey")

  accountId String
  account   Account @relation("FromAccount", fields: [accountId, familyId], references: [id, familyId], onDelete: Restrict, onUpdate: Cascade, map: "Transaction_accountId_familyId_fkey")

  toAccountId String?
  toAccount   Account? @relation("ToAccount", fields: [toAccountId, familyId], references: [id, familyId], onDelete: Restrict, onUpdate: Cascade, map: "Transaction_toAccountId_familyId_fkey")

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  familyId String
  family   Family @relation(fields: [familyId], references: [id])

  // Relasi ke Transfer (Hanya terisi jika type == "transfer")
  transferOut Transfer? @relation("OutflowTransaction")
  transferIn  Transfer? @relation("InflowTransaction")
  // This row is the FX fee leg of a transfer (kind == "fx_fee"); ADR-0035 §6.
  feeForTransfer Transfer? @relation("FxFeeTransaction")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Split Transaction Engine: 1 transaksi = banyak line item kategori
  isSplit      Boolean      @default(false)
  splitEntries SplitEntry[]

  // Strategic indexes (see ADR-0003). Prisma's SQLite/libSQL provider does
  // NOT auto-index foreign-key columns, so these are not redundant.
  // Main list query (`getTransactionsFn`): filter on deletedAt IS NULL,
  // order by date DESC. Covering index avoids a full scan on every page.
  // Per-account history (account-detail drill-down planned post-ADR-0004).
  // Primary list-page index for tenant-scoped queries
  // Aggregations.
  @@index([deletedAt, date(sort: Desc)])
  @@index([accountId, date(sort: Desc)])
  @@index([familyId, deletedAt, date(sort: Desc)])
  @@index([categoryId])
  @@index([merchantId])
  @@unique([familyId, idempotencyKey], name: "tx_family_idempotency", map: "tx_family_idempotency")
}

model IdempotencyRecord {
  id           String   @id @default(cuid())
  familyId     String
  family       Family   @relation(fields: [familyId], references: [id], onDelete: Restrict)
  endpoint     String
  key          String
  requestHash  String
  statusCode   Int
  responseJson Json
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@unique([familyId, endpoint, key])
  @@index([expiresAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  familyId       String
  userId         String
  action         String
  entityType     String
  entityId       String
  beforeJson     Json?
  afterJson      Json?
  ip             String?
  userAgent      String?
  requestId      String
  idempotencyKey String?
  createdAt      DateTime @default(now())

  @@index([familyId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([entityType, entityId])
  @@index([requestId])
  @@unique([createdAt, id])
}

model Transfer {
  id String @id @default(cuid())

  // Transaksi Uang Keluar (Sumber). ADR-0048 §4: nullable — a valuation-linked
  // move (one leg cash, one leg a Valuation on a balanceSource="valuation"
  // account) sets exactly one of outflowTransactionId/inflowTransactionId,
  // never both null and never both set alongside valuationId. See
  // transfer_leg_shape CHECK below.
  outflowTransactionId String?      @unique
  outflowTransaction   Transaction? @relation("OutflowTransaction", fields: [outflowTransactionId], references: [id], onDelete: Restrict)

  // Transaksi Uang Masuk (Tujuan). ADR-0048 §4: nullable, see above.
  inflowTransactionId String?      @unique
  inflowTransaction   Transaction? @relation("InflowTransaction", fields: [inflowTransactionId], references: [id], onDelete: Restrict)

  // ADR-0048 §4: the valuation-tracked side of a valuation-linked move — the
  // NEW Valuation written on the balanceSource="valuation" account in the same
  // $transaction as the one cash Transaction leg above. NULL for a classic
  // dual-Transaction transfer.
  valuationId String?    @unique
  valuation   Valuation? @relation(fields: [valuationId], references: [id], onDelete: Restrict)

  // Cross-currency rate recorded on the canonical pairing record (ADR-0035 §5).
  // Implied source->dest rate, 1e12-scaled, DERIVED from the two native legs.
  // NULL for same-currency transfers. `fromCurrency`/`toCurrency` are audit
  // denormalizations mirroring the legs (shape-CHECKed, no FK).
  fxRateScaled BigInt?
  fromCurrency String?
  toCurrency   String?

  // Optional FX fee leg (kind == "fx_fee", a standalone expense row). ADR-0035 §6.
  feeTransactionId String?      @unique
  feeTransaction   Transaction? @relation("FxFeeTransaction", fields: [feeTransactionId], references: [id], onDelete: Restrict)

  // Soft-delete shadow (PER-20 / ADR-0012). A transfer is one money movement;
  // when either Transaction leg is soft-deleted, this column is set in the
  // same `$transaction` so the audit trail of "was money moved? when? who?"
  // survives, and so the database refuses any future hard DELETE that would
  // erase the Transfer row alongside its legs.
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([deletedAt])
}

// Split Transaction Engine: Line Items untuk satu struk multi-kategori

model SplitEntry {
  id          String @id @default(cuid())
  description String
  // Stored in MINOR UNITS, same currency as the parent transaction.
  // Always positive (absolute value); sign is carried by the parent's `type`.
  amount      BigInt

  // Relasi ke Transaksi Induk
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  // Optional: Kategori & Merchant per baris
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  merchantId String?
  merchant   Merchant? @relation(fields: [merchantId], references: [id])

  createdAt DateTime @default(now())

  // Hot read path: hydrating split children for a transaction list.
  // See ADR-0003.
  @@index([transactionId])
}

// ==========================================
// The Smart Rules Engine
// ==========================================

model SmartRule {
  id      String @id @default(cuid())
  keyword String // Stores comma-separated strings (e.g. "fore, coffeeshop, kenangan")

  // The 'THEN' assignments: if matches, assign these
  merchantId String?
  merchant   Merchant? @relation(fields: [merchantId, familyId], references: [id, familyId], onDelete: Restrict, onUpdate: Cascade, map: "SmartRule_merchantId_familyId_fkey")
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  familyId String
  family   Family @relation(fields: [familyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Tenant-scoped rule evaluation (see ADR-0003).
  @@index([familyId])
}

model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("AuthAccount")
}

// ==========================================
// Valuation primitive (PER-146 / ADR-0034)
// ==========================================
// A dated, audited snapshot of an account's value, sitting alongside
// `Transaction` in the ledger. Three roles: (1) opening balance as auditable
// history, (2) tracked/non-cash asset value that changes without transactions,
// (3) reconciliation anchors feeding the read-only drift detector.
//
// Balance derivation (ADR-0034 §4/§5):
//   - transaction_flow (cash-like): balance = opening valuation + Σ transactions
//     since the opening date; non-opening valuations are observations that feed
//     the drift detector only and never move Account.balance.
//   - valuation (tracked): balance = latest valuation value (no transaction sum).
//
// `value` is SIGNED minor units of `currency`, same convention as
// `Account.balance` (ASSET/TRACKED_ASSET >= 0, LIABILITY <= 0). A table CHECK
// cannot join to Account, so `normalBalance` is denormalized at write time and
// CHECKed here, mirroring how `balanceSource` is denormalized onto Account.
// See ADR-0034 §9. Append-only history: soft-delete only, never hard delete.
model Valuation {
  id String @id @default(cuid())

  // SIGNED, MINOR UNITS of `currency`. See src/lib/money.ts for arithmetic.
  value            BigInt
  currency         String
  currencyRegistry Iso4217Currency @relation("ValuationCurrency", fields: [currency], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "valuation_currency_is_iso_4217")

  // Date-only "as-of" of the valuation (not a wall-clock timestamp).
  valuationDate DateTime @db.Date

  // Domain: "opening" | "reconciliation" | "market" | "manual" (CHECK in migration).
  type   String
  source String  @default("manual")
  note   String?

  // Denormalized normal-balance discriminator: "POSITIVE" | "NEGATIVE", copied
  // from the account at write time so the value-sign rule is a pure table CHECK.
  normalBalance String
  // Orthogonal to normalBalance (which still means "this account's usual
  // class-implied sign"): true iff the account's accountType is in the
  // ADR-0045 negative-balance carve-out (DEPOSITORY/E_WALLET), copied from
  // app_allows_negative_asset(accountType) at write time so valuation_value_sign
  // can allow a genuinely negative ASSET anchor (e.g. an overdrawn e-wallet)
  // without overloading normalBalance's meaning. See ADR-0034 §9 amendment / ADR-0045.
  allowsNegativeAsset Boolean @default(false)

  // Base-currency projection (ADR-0035 §4/§7), keyed off `valuationDate`. Same
  // all-three-or-none, rebuildable, FX-pending-tolerant rules as Transaction.
  baseValue        BigInt?
  baseCurrency     String?
  baseCurrencyRegistry Iso4217Currency? @relation("ValuationBaseCurrency", fields: [baseCurrency], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "valuation_base_currency_is_iso_4217")
  fxRateScaled     BigInt?
  fxRateSnapshotId String?

  // Soft-delete tombstone; valuation history is never hard deleted.
  deletedAt DateTime?

  // Actor stored as a plain id with no relation, mirroring AuditLog.userId.
  createdById String
  createdAt   DateTime @default(now())

  accountId String
  account   Account @relation(fields: [accountId, familyId], references: [id, familyId], onDelete: Restrict, onUpdate: Cascade, map: "Valuation_accountId_familyId_fkey")

  familyId String
  family   Family @relation(fields: [familyId], references: [id])

  // ADR-0048 §4: back-relation for the optional Transfer.valuationId leg — a
  // valuation-linked money move links its Valuation write here. NULL for the
  // (still-common) standalone valuation with no linked transfer.
  transfer Transfer?

  // Latest-valuation-per-account (tracked balance + rebuild) and
  // type lookups (opening anchor / reconciliation drift).
  @@index([familyId, accountId, valuationDate(sort: Desc)])
  @@index([familyId, accountId, type])
}

// Dated FX rate snapshot (ADR-0035 §2). Tenant-scoped, directed `from -> to`
// (canonical use is `foreign -> base`). Resolution = greatest `asOfDate <= date`.
// `rateScaled` is a 1e12-scaled major->major quote (see src/lib/fx.ts). One rate
// per (family, from, to, date); `source` is non-key provenance. Idempotent upsert
// by the natural key. RLS-isolated like Account/Transaction/Valuation.
model FxRateSnapshot {
  id String @id @default(cuid())

  fromCurrency         String
  fromCurrencyRegistry Iso4217Currency @relation("FxRateFromCurrency", fields: [fromCurrency], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "fx_from_currency_is_iso_4217")
  toCurrency           String
  toCurrencyRegistry   Iso4217Currency @relation("FxRateToCurrency", fields: [toCurrency], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "fx_to_currency_is_iso_4217")

  // 1e12-scaled rate; CHECK (> 0) in migration.
  rateScaled BigInt

  // Date-only "as-of" (not wall-clock). Step-function resolution, no interpolation.
  asOfDate DateTime @db.Date

  // Domain: "manual" | "seed" | "provider" (CHECK in migration).
  source String @default("manual")

  // Actor as a plain id with no relation, mirroring Valuation.createdById.
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  familyId String
  family   Family @relation(fields: [familyId], references: [id])

  @@unique([familyId, fromCurrency, toCurrency, asOfDate], name: "fx_rate_snapshot_unique", map: "fx_rate_snapshot_unique")
  @@index([familyId, fromCurrency, toCurrency, asOfDate(sort: Desc)])
}

// ADR-0037 (PER-148) — Budget period model.
//
// A `Budget` is a CONCRETE, tenant-scoped PERIOD INSTANCE (e.g. "June 2026"),
// not a recurring template. Its only durable money is the per-category
// `allocatedAmount` on `BudgetCategory`; actual/remaining/over are derived
// read-side from the canonical ledger (ADR-0008 §7) normalized via each
// transaction's materialized `baseAmount` (ADR-0035). `periodKind` is reserved
// for weekly/custom; only `monthly` is built in this slice. Date-only anchors
// are interpreted in the family timezone. See ADR-0037.
model Budget {
  id          String    @id @default(cuid())
  familyId    String
  family      Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)

  name        String
  periodKind  String    @default("monthly") // 'monthly' | 'weekly' | 'custom' (DB CHECK)
  periodStart DateTime  @db.Date
  periodEnd   DateTime  @db.Date

  // Captured = Family.currency (base) at creation; allocations are stored in
  // this currency's minor units. Base is immutable post-onboarding (ADR-0035).
  currency         String
  currencyRegistry Iso4217Currency @relation("BudgetCurrency", fields: [currency], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "budget_currency_is_iso_4217")

  archivedAt  DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  categories  BudgetCategory[]

  // One budget per family per period kind per start (idempotent upsert target).
  @@unique([familyId, periodKind, periodStart], name: "budget_family_period_unique", map: "budget_family_period_unique")
  // Composite-FK target so BudgetCategory can never point at another family's
  // budget even with a forged budgetId (ADR-0010 pattern).
  @@unique([id, familyId], map: "Budget_id_familyId_key")
  @@index([familyId, archivedAt, periodStart(sort: Desc)])
}

model BudgetCategory {
  id         String @id @default(cuid())
  // Denormalized for the composite tenant FK + RLS guard.
  familyId   String
  budgetId   String
  budget     Budget @relation(fields: [budgetId, familyId], references: [id, familyId], onDelete: Cascade, onUpdate: Cascade, map: "budget_category_budget_family_fkey")

  // System (isSystem, familyId NULL) or tenant-owned category; cross-tenant
  // protection is app-layer validation (ADR-0011), since a composite FK is
  // impossible against nullable-family system categories.
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Stored in MINOR UNITS of the parent Budget.currency (base). CHECK (>= 0).
  allocatedAmount BigInt
  // 'none' | 'carryover' (DB CHECK). Reserved: stored, not computed this slice.
  rolloverPolicy String @default("none")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // One allocation per category per budget.
  @@unique([budgetId, categoryId], name: "budget_category_unique", map: "budget_category_unique")
  @@index([familyId])
  @@index([categoryId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("Verification")
}

// ============================================================================
// PER-82 / ADR-0039 — Import staging (source-agnostic spine)
//
// Raw import data is staging data, not ledger data (ADR-0008 §5). Bank/CSV/
// provider rows land here first; only explicitly `confirmed`, tenant-validated,
// deduplicated rows are promoted into canonical `Transaction`s through the
// shared ledger create core. Provider columns are reserved-nullable for
// PER-118 / ADR-0015 — that slice only ADDS `ProviderConnection` + populates
// them; it never redefines these tables.
// ============================================================================

model ImportBatch {
  id          String @id @default(cuid())
  familyId    String
  family      Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  // Acting member (User.id). Plain id, not an FK, like Transaction.userId.
  createdById String

  // 'csv_upload' | 'provider' | 'migration' (DB CHECK). 'provider' reserved for
  // PER-118; 'migration' is a full-family bring-your-own-data import (ADR-0041).
  sourceKind  String
  // Provider-agnostic origin label for sourceKind='migration' (e.g. 'sure'), so
  // future migrations don't hardcode a per-provider sourceKind (ADR-0041 §8).
  provider    String?
  // OPTIONAL batch-level default/hint only. The AUTHORITATIVE target account is
  // per-row on RawImportedTransaction, because one file can span many accounts.
  accountId   String?
  // 'pending' | 'ready_for_review' | 'partially_promoted' | 'completed' |
  // 'failed' (DB CHECK). Coarse, derived rollup — never authoritative over row
  // status.
  status      String @default("pending")
  // sha256 of the raw file/payload bytes. Per-file batch dedup (ADR-0039 §5):
  // re-uploading the identical file returns the existing batch, no re-stage.
  contentHash String
  // Client UUIDv7 for the create-batch endpoint replay (ADR-0006).
  idempotencyKey String?

  // Derived rollup counters (informational).
  totalRows     Int @default(0)
  duplicateRows Int @default(0)
  errorRows     Int @default(0)
  promotedRows  Int @default(0)

  // Reserved for PER-118 / ADR-0015 (NULL in PER-82).
  providerConnectionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  rawRows   RawImportedTransaction[]
  artifacts ImportBatchArtifact[]

  // Per-file batch dedup target (ADR-0039 §5).
  @@unique([familyId, sourceKind, contentHash], name: "import_batch_content_dedup", map: "import_batch_content_dedup")
  // Composite-FK target so a raw row can never point at another family's batch
  // even with a forged batchId (ADR-0010 pattern).
  @@unique([id, familyId], map: "ImportBatch_id_familyId_key")
  @@index([familyId, status])
}

model RawImportedTransaction {
  id            String @id @default(cuid())
  familyId      String
  family        Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId, familyId], references: [id, familyId], onDelete: Cascade, onUpdate: Cascade, map: "raw_import_batch_family_fkey")

  // AUTHORITATIVE per-row target account (composite tenant FK, ADR-0010).
  accountId String
  account   Account @relation(fields: [accountId, familyId], references: [id, familyId], onDelete: Restrict, onUpdate: Cascade, map: "raw_import_account_family_fkey")

  // (1) Lossless raw — IMMUTABLE after insert (retention/provenance evidence).
  rawPayload Json

  // (2) Normalized candidate — pipeline-filled, mutable working area.
  externalId  String? // provider dedup key; NULL for CSV
  type        String? // 'income' | 'expense' (DB CHECK; income/expense only)
  amount      BigInt? // SIGNED minor units once normalized (DB CHECK by type)
  currency    String? // resolved at normalize = account currency (part of fingerprint)
  date        DateTime?
  description String?

  // (3) Enrichment + dedup verdict — suggestion columns; never canonical writes.
  fingerprint              String?
  // 'pending' | 'normalized' | 'duplicate' | 'error' | 'confirmed' | 'promoted'
  // | 'rejected' (DB CHECK). 'promoted' is the sole irreversible terminal.
  rowStatus                String  @default("pending")
  possibleDuplicate        Boolean @default(false) // soft near-dup flag
  duplicateOfTransactionId String?
  suggestedCategoryId      String?
  suggestedMerchantId      String?
  matchedSmartRuleId       String?
  errorReason              String?

  // UUIDv7 (becomes Transaction.idempotencyKey, ADR-0006); minted at stage time
  // and threaded into the canonical create so re-promotion never double-books.
  promotionIdempotencyKey String
  promotedTransactionId   String? // set iff rowStatus='promoted' (DB CHECK)

  // Reserved for PER-118 / ADR-0015 (NULL in PER-82).
  providerConnectionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Per-row promotion idempotency (durable backstop, ADR-0039 §5/§9).
  @@unique([familyId, promotionIdempotencyKey], name: "raw_import_promotion_key", map: "raw_import_promotion_key")
  @@index([importBatchId, rowStatus])
  @@index([familyId, fingerprint])
  @@index([accountId])
}

// ADR-0041 §8 — lossless raw-bundle provenance for a full-family migration.
//
// One row per uploaded bundle (`all.ndjson`). The raw bytes are retained as
// tenant-private provenance AND as the durable source for the deferred Phase
// 2/3 entities (Balance/Transfer/Trade/Holding/Valuation/Recurring/Rule), so a
// re-run never re-uploads. The bundle holds real financial PII; encryption-at-
// rest is the deployment's DB/disk-level encryption (NOT app-level column
// crypto), gated by RLS app_is_active_member — consistent with the same PII
// already living plaintext in canonical Transaction/Account rows.
//
// `storageKind` is a forward-compat discriminator: today only 'inline_bytea'
// (gzip(all.ndjson) in `bytes`); a future object-store form adds 'object_store'
// + `storageRef` WITHOUT a breaking schema change. `contentHash` + `byteSize`
// provide one-shot idempotency (§7) and integrity. Composite tenant FK
// (importBatchId, familyId) + FORCE RLS in raw SQL (migration
// `sure_migration_bindings`).
model ImportBatchArtifact {
  id            String @id @default(cuid())
  familyId      String
  family        Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId, familyId], references: [id, familyId], onDelete: Cascade, onUpdate: Cascade, map: "import_artifact_batch_family_fkey")

  filename    String
  // 'inline_bytea' today; 'object_store' reserved (DB CHECK).
  storageKind String @default("inline_bytea")
  // sha256 of the RAW (pre-compression) bundle bytes — the one-shot dedup anchor.
  contentHash String
  // Size of the raw (pre-compression) bundle in bytes. Enforced under a guard.
  byteSize    Int
  // gzip(all.ndjson) bytes for storageKind='inline_bytea'. NULL when an external
  // store holds them (storageKind='object_store', reserved).
  bytes       Bytes?
  // External-store key/URL for storageKind='object_store' (reserved-nullable).
  storageRef  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([importBatchId, contentHash], name: "import_artifact_batch_content", map: "import_artifact_batch_content")
  @@index([familyId])
}
